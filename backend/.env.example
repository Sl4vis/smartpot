# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# AI - Groq (primárne, zadarmo: console.groq.com)
GROQ_API_KEY=your-groq-api-key

# AI - Gemini (záloha, zadarmo: aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Azure IoT Hub - Event Hub endpoint
# Nájdeš: Azure Portal → IoT Hub → Built-in endpoints → Event Hub-compatible endpoint
AZURE_IOT_HUB_EVENT_HUB_CONNECTION_STRING=Endpoint=sb://ihsuprodxxx.servicebus.windows.net/;SharedAccessKeyName=iothubowner;SharedAccessKey=xxx;EntityPath=xxx

# Web Push (vygeneruj napr. cez: npx web-push generate-vapid-keys)
WEB_PUSH_VAPID_PUBLIC_KEY=your-public-vapid-key
WEB_PUSH_VAPID_PRIVATE_KEY=your-private-vapid-key
WEB_PUSH_SUBJECT=mailto:you@example.com
PUSH_DIGEST_INTERVAL_MINUTES=60
PUSH_SCHEDULER_INTERVAL_MINUTES=10
DEVICE_OFFLINE_AFTER_MINUTES=10

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
