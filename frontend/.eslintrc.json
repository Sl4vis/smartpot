{
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "plugins": ["react"],
  "settings": {
    "react": { "version": "detect" }
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "react/react-in-jsx-scope": "off"
  }
}
